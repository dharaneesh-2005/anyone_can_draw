# Proxy Server URL (optional - auto-detected by default)
# Only set this if you need to override the automatic detection
# VITE_PROXY_URL=http://192.168.31.107:3000

# Backend Configuration (for server.js)
# ComfyUI runs locally on the same machine as the proxy server
COMFYUI_URL=http://127.0.0.1:8000
PORT=3000
